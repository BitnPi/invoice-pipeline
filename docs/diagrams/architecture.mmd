flowchart LR
    subgraph SOURCE["Sources"]
        PDF[PDF / Image<br/>invoices]
    end

    subgraph PIPELINE["Pipeline daemon (Python)"]
        WATCH[Folder Watcher<br/>poll + batch]
        PROC[Job Processor<br/>workers, retries]
        ARCHIVE[(Archive<br/>by type & date)]
    end

    subgraph LLM["Local inference"]
        SERVER[llama-server<br/>on-demand]
        MODEL[Qwen3-VL-4B<br/>vision LLM]
        SERVER --- MODEL
    end

    subgraph STORAGE["Storage"]
        JSON[result.json<br/>per invoice]
        GRAPH[(Kuzu<br/>property graph)]
    end

    subgraph QUERY["Query layer"]
        EXP[Kuzu Explorer<br/>web UI]
        CLI[Cypher CLI<br/>scripts/queries.py]
        API[Python kuzu lib<br/>direct queries]
    end

    PDF --> WATCH
    WATCH --> PROC
    PROC -->|HTTP| SERVER
    PROC --> JSON
    PROC --> ARCHIVE
    JSON -->|auto-ingest<br/>+ entity resolution| GRAPH
    GRAPH --> EXP
    GRAPH --> CLI
    GRAPH --> API

